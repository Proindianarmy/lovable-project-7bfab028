# ── Frontend API URL ───────────────────────────────────────────────────────
# Use a RELATIVE path "/api" — the Vite dev proxy routes this to the backend
# automatically, so the browser never makes a cross-origin request (no CORS).
#
# In production (same-domain deploy), this still works as-is.
# If your production frontend and backend are on DIFFERENT domains, change to:
#   VITE_API_URL=https://your-backend.com/api
VITE_API_URL=/api

# Optional: Sightengine AI image moderation (leave blank to skip)
VITE_SIGHTENGINE_USER=1898802268
