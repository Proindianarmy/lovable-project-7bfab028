NODE_ENV=development

# ── Server ────────────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/issuesnap
# Atlas alternative:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/issuesnap?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_string_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# ── Admin seed credentials ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@issuesnap.com
ADMIN_PASSWORD=Admin@1234

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:8080,http://localhost:5173,http://localhost:3000

# ── Email — OPTIONAL, leave both sections blank for console OTP mode ───────
# Pick ONE option below. If SMTP_HOST is set, it takes priority over GMAIL_*.
#
# Option A — Generic SMTP (SendGrid, Mailgun, AWS SES, Outlook, your own server, etc.)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your_smtp_password_or_api_key
#
# Option B — Gmail with an App Password (requires 2-Step Verification enabled
# on the Google account, then generate a 16-char password at
# https://myaccount.google.com/apppasswords — your normal Gmail password will
# NOT work and causes "535 Username and Password not accepted").
# GMAIL_USER=your.gmail@gmail.com
# GMAIL_APP_PASS=your16characterapppassword

# ── Image moderation (AI-generated / civic-issue verification) ─────────────
# Powers POST /api/reports/validate-image. Get a key at https://console.anthropic.com
# If left blank, image verification is skipped (logged as a warning) so local dev
# still works — but this MUST be set before deploying to production.
ANTHROPIC_API_KEY=

EMAIL_FROM=noreply@issuesnap.com
